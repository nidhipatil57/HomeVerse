datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String   @id
  name             String
  email            String   @unique
  phone            String
  role             String   // secretary, security, resident, worker, student, warden
  portal           String   // society, hostel
  unit             String?  // Flat or Room number
  building         String?  // A Wing, Wing A, etc.
  societyName      String?
  hostelName       String?
  collegeName      String?
  communityCode    String?
  ownerOrTenant    String?  // Owner, Tenant
  joinedAt         String?
  status           String   @default("approved") // approved, pending, rejected
  password         String   // Hashed password
  
  // Secretary fields
  designation      String?
  committeeId      String?
  
  // Security fields
  employeeId       String?
  workingShift     String?
  gate             String?
  
  // Student/Warden fields
  gender           String?
  course           String?
  year             String?
  branch           String?
  assignedWing     String?

  // Worker fields
  workerCategory   String?
  availability     String?  // Available, Busy
  rating           Float?
  experience       String?
  specializations  String[]

  // Relations
  residentAssignments ResidentWorkerAssignment[] @relation("ResidentAssignments")
  workerAssignments   ResidentWorkerAssignment[] @relation("WorkerAssignments")
  complaintsRaised Complaint[]           @relation("ComplaintsRaised")
  complaintsAssigned Complaint[]         @relation("ComplaintsAssigned")
  subscribedComplaints ComplaintSubscriber[]
  chatMessages     ComplaintChatMessage[]
  notifications    Notification[]
  roommatePreference RoommatePreference?
  gatePasses       GatePass[]
  facilityBookings FacilityBooking[]
  rsvps            EventRsvp[]
  eventRegistrations EventRegistration[]
  eventVolunteers    EventVolunteer[]
  eventAttendances   EventAttendance[]
  eventFeedbacks     EventFeedback[]
  eventPollVotes     EventPollVote[]
  foundItems       FoundItem[]           @relation("ReporterUser")
  claims           Claim[]               @relation("ResidentClaims")
  lostReports      LostReport[]          @relation("ResidentLostReports")
}

model Complaint {
  id                  String   @id
  title               String
  description         String
  category            String
  priority            String
  raisedBy            String
  raisedByName        String
  unit                String
  building            String
  status              String
  portal              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  emergency           Boolean  @default(false)
  images              String[]
  videos              String[]
  resolvedAt          DateTime?
  assignedTo          String?
  assignedToId        String?
  duplicateGroup      String[]
  isDuplicate         Boolean  @default(false)
  possibleDuplicateOf String?

  // Relations
  raisedByUser        User     @relation("ComplaintsRaised", fields: [raisedBy], references: [id], onDelete: Cascade)
  assignedToUser      User?    @relation("ComplaintsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  subscribers         ComplaintSubscriber[]
  chat                ComplaintChatMessage[]
  timeline            ComplaintTimeline[]

  @@index([portal])
  @@index([status])
  @@index([raisedBy])
  @@index([assignedToId])
}

model ComplaintSubscriber {
  id          String    @id @default(uuid())
  complaintId String
  userId      String
  userName    String
  unit        String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([userId])
}

model ComplaintChatMessage {
  id          String    @id @default(uuid())
  complaintId String
  senderId    String
  senderName  String
  senderRole  String
  message     String
  timestamp   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([senderId])
}

model ComplaintTimeline {
  id          String    @id @default(uuid())
  complaintId String
  status      String
  timestamp   DateTime  @default(now())
  note        String
  by          String?
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model LeaveRequest {
  id            String   @id
  studentId     String
  studentName   String
  room          String
  parentContact String
  reason        String
  fromDate      String
  toDate        String
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  @@index([studentId])
}

model Visitor {
  id                 String   @id
  name               String
  phone              String
  purpose            String
  visitingUnit       String
  visitingResident   String
  visitingResidentId String?
  status             String
  expectedAt         String?
  checkInTime        String?
  checkOutTime       String?
  date               String
  portal             String
  approvedBy         String?
  vehicleNumber      String?

  @@index([visitingUnit])
  @@index([visitingResidentId])
  @@index([portal])
}

model LaundrySlot {
  id            String  @id
  machineId     String
  machineName   String
  date          String
  timeSlot      String
  bookedBy      String?
  bookedById    String?
  communityCode String  @default("VESIT26")

  @@index([bookedById])
}

model Parcel {
  id             String  @id
  recipientName  String
  recipientId    String?
  unit           String
  carrier        String
  trackingNumber String?
  status         String
  otp            String?
  dateReceived   String
  timeReceived   String
  dateReleased   String?
  timeReleased   String?
  portal         String
  communityCode  String

  @@index([recipientId])
  @@index([unit])
  @@index([portal])
}

model FacilityBooking {
  id            String @id
  facilityName  String
  residentName  String
  residentId    String
  date          String
  timeSlot      String
  purpose       String
  status        String
  communityCode String
  user          User   @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
}

model MarketplaceItem {
  id          String   @id
  title       String
  description String
  price       String
  sellerId    String
  sellerName  String
  category    String
  status      String
  portal      String
  createdAt   DateTime @default(now())
  images      String[]

  @@index([sellerId])
  @@index([portal])
}

model FoundItem {
  id              String   @id
  reporterId      String
  reporterName    String
  communityCode   String
  category        String
  brand           String?
  colour          String?
  description     String
  images          String[]
  foundLocation   String
  dateFound       String
  timeFound       String
  additionalNotes String?
  status          String   // "Pending Verification", "Available for Claim", "Claim Pending Verification", "Ready for Pickup", "Returned", "Rejected"
  portal          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  claims          Claim[]
  matches         ItemMatch[]
  reporter        User     @relation("ReporterUser", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([communityCode])
  @@index([portal])
}

model Claim {
  id                 String    @id
  itemId             String
  residentId         String
  residentName       String
  claimReason        String
  itemDetails        String?
  proofImage         String?
  contactNumber      String?
  status             String    // "Claim Pending Verification", "Ready for Pickup", "Returned", "Rejected"
  approvalDate       DateTime?
  collectionDate     DateTime?
  collectionTime     String?
  collectedBy        String?
  verifiedBySecurity String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  item               FoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  resident           User      @relation("ResidentClaims", fields: [residentId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([residentId])
}

model LostReport {
  id                    String      @id
  residentId            String
  itemName              String
  category              String
  brand                 String?
  colour                String?
  description           String
  distinguishingFeatures String?
  dateLost              String
  timeLost              String?
  lastSeenLocation      String
  status                String      // "Searching", "Possible Match Found", "Matched", "Returned", "Closed"
  images                String[]
  additionalNotes       String?
  portal                String      // "society", "hostel"
  communityCode         String
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  resident              User        @relation("ResidentLostReports", fields: [residentId], references: [id], onDelete: Cascade)
  matches               ItemMatch[]

  @@index([residentId])
  @@index([communityCode])
  @@index([portal])
}

model ItemMatch {
  id               String     @id
  lostReportId     String
  foundItemId      String
  status           String     // "Suggested", "Confirmed", "Rejected"
  verifiedBy       String?
  verificationDate DateTime?
  collectionDate   DateTime?
  collectionTime   String?
  collectedBy      String?
  securityNote     String?
  additionalPhoto  String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  lostReport       LostReport @relation(fields: [lostReportId], references: [id], onDelete: Cascade)
  foundItem        FoundItem  @relation(fields: [foundItemId], references: [id], onDelete: Cascade)

  @@index([lostReportId])
  @@index([foundItemId])
}

model RoomChangeRequest {
  id            String   @id
  studentId     String
  studentName   String
  currentRoom   String
  preferredRoom String
  reason        String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  communityCode String

  @@index([studentId])
}

model MaintenanceBill {
  id           String  @id
  residentId   String
  residentName String
  unit         String
  month        String
  amount       Float
  dueDate      String
  status       String
  paidOn       String?
  description  String?
  lateFee      Float?

  @@index([residentId])
  @@index([unit])
}

model CommunityEvent {
  id                    String              @id
  title                 String
  description           String
  date                  String
  time                  String
  location              String
  organizer             String
  priority              String
  communityCode         String
  
  // New fields for comprehensive Events Module
  category              String              @default("Other") // Festival, Sports, etc.
  bannerImage           String?             // URL or base64
  endTime               String?             // e.g. "22:00"
  contactPerson         String?
  contactNumber         String?
  maxParticipants       Int?
  registrationDeadline  String?
  entryFee              Float?
  registrationRequired  Boolean             @default(true)
  volunteerRequired     Boolean             @default(false)
  visibility            String              @default("public") // public, private
  rules                 String?
  thingsToBring         String?
  budget                Float               @default(0.0)
  status                String              @default("Active") // Active, Cancelled
  createdAt             DateTime            @default(now())
  
  // Relations
  rsvps                 EventRsvp[]
  registrations         EventRegistration[]
  volunteers            EventVolunteer[]
  attendance            EventAttendance[]
  feedbacks             EventFeedback[]
  gallery               EventGalleryPhoto[]
  polls                 EventPoll[]
  expenses              EventExpense[]
}

model EventRegistration {
  id             String         @id @default(uuid())
  eventId        String
  userId         String
  userName       String
  flatNumber     String?
  contactNumber  String?
  registeredAt   DateTime       @default(now())
  guestCount     Int            @default(0)
  guestNames     String?
  rsvpStatus     String         @default("Going") // Going, Maybe, Not Going
  
  event          CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}

model EventVolunteer {
  id             String         @id @default(uuid())
  eventId        String
  userId         String
  volunteerName  String
  flatNumber     String?
  contactNumber  String?
  role           String         // Decoration, Registration Desk, Food Distribution, etc.
  volunteeredAt  DateTime       @default(now())

  event          CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}

model EventAttendance {
  id             String         @id @default(uuid())
  eventId        String
  userId         String
  userName       String
  flatNumber     String?
  markedAt       DateTime       @default(now())
  markedBy       String         @default("Secretary")

  event          CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}

model EventFeedback {
  id                 String         @id @default(uuid())
  eventId            String
  userId             String
  userName           String
  rating             Int            // 1-5
  comment            String?
  suggestions        String?
  wouldAttendSimilar  Boolean        @default(true)
  submittedAt        DateTime       @default(now())

  event          CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}

model EventGalleryPhoto {
  id         String         @id @default(uuid())
  eventId    String
  imageUrl   String
  uploadedAt DateTime       @default(now())

  event      CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventPoll {
  id            String          @id @default(uuid())
  eventId       String
  question      String
  options       String[]
  status        String          @default("Open") // Open, Closed
  createdAt     DateTime        @default(now())

  event         CommunityEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes         EventPollVote[]

  @@index([eventId])
}

model EventPollVote {
  id        String    @id @default(uuid())
  pollId    String
  userId    String
  userName  String
  option    String
  votedAt   DateTime  @default(now())

  poll      EventPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pollId])
  @@index([userId])
}

model EventExpense {
  id          String         @id @default(uuid())
  eventId     String
  category    String         // Decoration, Food, Stage, Prizes, Electricity, Cleaning, Miscellaneous
  amount      Float
  description String?
  date        String

  event       CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventRsvp {
  id        String         @id @default(uuid())
  eventId   String
  userId    String
  userName  String
  status    String
  event     CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}

model Notification {
  id        String   @id
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model RoommatePreference {
  id             String   @id @default(uuid())
  userId         String   @unique
  userName       String
  sleepingHabits String
  studyHours     String
  cleanliness    String
  smoking        Boolean
  foodPreference String
  interests      String[]
  roomPreference String
  communityCode  String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmergencyAlert {
  id            String    @id
  type          String
  reporterName  String
  reporterId    String
  unit          String
  status        String
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?
  communityCode String
}

model GatePass {
  id            String @id
  visitorName   String
  purpose       String
  validOn       String
  qrCodeData    String
  status        String
  residentId    String
  residentName  String
  unit          String
  communityCode String
  user          User   @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
}

model VehicleLog {
  id            String    @id
  vehicleNumber String
  ownerName     String
  ownerUnit     String?
  type          String
  entryTime     DateTime  @default(now())
  exitTime      DateTime?
  gate          String
  loggedBy      String
  communityCode String

  @@index([vehicleNumber])
}

model IncidentReport {
  id          String   @id
  title       String
  time        String
  location    String
  description String
  type        String
  status      String
  reporter    String
  createdAt   DateTime @default(now())
}

model Announcement {
  id         String   @id
  title      String
  content    String
  author     String
  authorRole String
  priority   String
  createdAt  DateTime @default(now())
  tags       String[]
}

model FlatInfo {
  id           String  @id
  building     String
  wing         String
  floor        Int
  flatNumber   String
  status       String
  residentId   String?
  residentName String?

  @@index([residentId])
}

model RentRecord {
  id         String  @id
  unit       String
  building   String
  tenantName String
  tenantId   String?
  amount     Float
  dueDate    String
  status     String
  paidOn     String?

  @@index([tenantId])
}

model FavoriteVisitor {
  id           String @id
  name         String
  phone        String
  category     String
  residentId   String
  visitingUnit String

  @@index([residentId])
}

model Helper {
  id                  String   @id
  name                String
  phone               String
  category            String
  expectedArrivalTime String
  expectedExitTime    String
  workingDays         String[]
  assignedFlats       String[]
  createdBy           String
  code                String   @unique
}

model HelperAttendance {
  id            String    @id
  helperId      String
  helperName    String
  category      String
  checkInTime   DateTime?
  checkOutTime  DateTime?
  date          String
  assignedFlats String[]
  entryGate     String?
  exitGate      String?
  status        String    @default("checked-in")
  duration      Int?

  @@index([helperId])
  @@index([date])
}

model FlatAttendance {
  id               String    @id @default(uuid())
  helperId         String
  helperName       String
  date             String
  residentId       String
  residentName     String
  flatNumber       String
  checkInTime      DateTime  @default(now())
  checkOutTime     DateTime?
  duration         Int?
  servicePerformed String
  status           String    @default("working")
  notes            String?
  photoUrl         String?

  @@index([helperId])
  @@index([residentId])
  @@index([date])
}

model SocietyExpense {
  id       String  @id
  category String
  vendor   String
  amount   Float
  date     String
  notes    String?
}

model ResidentWorkerAssignment {
  id            String   @id @default(uuid())
  residentId    String
  workerId      String
  workingDays   String[]
  arrivalTime   String
  exitTime      String
  services      String[]
  createdAt     DateTime @default(now())

  resident      User     @relation("ResidentAssignments", fields: [residentId], references: [id], onDelete: Cascade)
  worker        User     @relation("WorkerAssignments", fields: [workerId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@index([workerId])
}

model SocietyCollection {
  id                  String   @id
  title               String
  description         String
  amount              Float
  type                String   // Mandatory, Voluntary
  dueDate             String
  applicableBuildings String[]
  applicableFlats    String[]
  visibility         String   // Everyone, Specific Buildings
  status             String   @default("active") // active, cancelled
  createdAt          DateTime @default(now())
  communityCode      String   @default("SUN123")
}

model ResidentPayment {
  id            String   @id
  residentId    String
  residentName  String
  unit          String   // Flat number
  building      String?  // Tower / Wing
  societyId     String   // communityCode (e.g. SUN123)
  paymentType   String   // Maintenance, Ganesh Festival, Building Repairs, etc.
  amount        Float
  status        String   // Paid, Pending, Overdue
  dueDate       String
  paidDate      String?
  receiptPath   String?
  transactionId String?
  paymentMethod String?  // UPI, Card, NetBanking, etc.
  referenceId   String?  // Reference to MaintenanceBill ID or SocietyCollection ID
  createdAt     DateTime @default(now())
  description   String?
  lateFee       Float?

  @@index([residentId])
  @@index([unit])
  @@index([paymentType])
}
